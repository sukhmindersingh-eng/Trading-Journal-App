<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trading Journal</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <h1>Trading Journal</h1>
    <form id="tradeForm">
        <label for="tradeType">Trade Type:</label>
        <select id="tradeType" required>
            <option value="buy">Buy</option>
            <option value="sell">Sell</option>
        </select>

        <label for="amount">Amount (USD):</label>
        <input type="number" id="amount" required min="0" step="0.01">

        <label for="date">Trade Date:</label>
        <input type="date" id="date" required>

        <button type="submit">Add Trade</button>
        <button type="button" id="clearForm">Clear</button>
    </form>

    <table id="tradeTable">
        <thead>
            <tr>
                <th>Trade Type</th>
                <th>Amount (USD)</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>

    <button id="exportBtn">Export</button>
    <input type="file" id="importBtn" accept="application/json">

    <script>
        const tradeForm = document.getElementById('tradeForm');
        const tradeTable = document.getElementById('tradeTable').getElementsByTagName('tbody')[0];
        const clearFormButton = document.getElementById('clearForm');
        const exportButton = document.getElementById('exportBtn');
        const importButton = document.getElementById('importBtn');
        let trades = [];

        tradeForm.addEventListener('submit', function(e) {
            e.preventDefault();
            const tradeType = document.getElementById('tradeType').value;
            const amount = parseFloat(document.getElementById('amount').value);
            const date = document.getElementById('date').value;

            if (amount > 0) {
                trades.push({ tradeType, amount, date });
                updateTable();
                tradeForm.reset();
            } else {
                alert('Please enter a valid amount greater than 0.');
            }
        });

        clearFormButton.addEventListener('click', () => tradeForm.reset());

        function updateTable() {
            tradeTable.innerHTML = '';
            trades.forEach((trade, index) => {
                const row = tradeTable.insertRow();
                row.insertCell(0).innerText = trade.tradeType;
                row.insertCell(1).innerText = `\$${trade.amount.toFixed(2)}`;
                row.insertCell(2).innerText = trade.date;
                const deleteCell = row.insertCell(3);
                const deleteButton = document.createElement('button');
                deleteButton.innerText = 'Delete';
                deleteButton.onclick = () => {
                    trades.splice(index, 1);
                    updateTable();
                };
                deleteCell.appendChild(deleteButton);
            });
        }

        exportButton.addEventListener('click', () => {
            const blob = new Blob([JSON.stringify(trades)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'trades.json';
            a.click();
            URL.revokeObjectURL(url);
        });

        importButton.addEventListener('change', (e) => {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = () => {
                    try {
                        trades = JSON.parse(reader.result);
                        updateTable();
                    } catch (err) {
                        alert('Failed to import trades. Please ensure the file is valid JSON.');
                    }
                };
                reader.readAsText(file);
            }
        });
    </script>
</body>
</html>